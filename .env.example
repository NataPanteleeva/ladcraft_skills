# Ladcraft credentials & API endpoint.
# Copy to .env and fill in. The helper scripts auto-load .env from the repo root.

# Account email used for login.
LADCRAFT_EMAIL=you@example.com

# Account password.
LADCRAFT_PASSWORD=your-password

# API base URL. Prod: https://api.ladcraft.ru  |  Dev: https://api.dev.e-ai.ladcloud.ru
LADCRAFT_API_URL=https://api.ladcraft.ru
