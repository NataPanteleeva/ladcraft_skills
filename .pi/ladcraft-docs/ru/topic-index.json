  "readingPlaybook": {
    "order": [
      "read .pi/ladcraft-docs/manifest.json first",
      "read .pi/ladcraft-docs/ru/topic-index.json and pick a topic branch",
      "open only files listed in manifest and selected topic",
      "for large files use chunked reads: start with offset=1, limit=120",
      "if a specific section is needed, locate heading keywords and read only nearby chunks",
      "for complex tasks, continue targeted reads until context is sufficient for one-pass deploy-ready output"
    ],
    "chunkDefaults": {
      "initialLimit": 120,
      "followupLimit": 120
    }
  }
